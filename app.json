{
  "expo": {
    "name": "Gatly",
    "slug": "gatly",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "gatly",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/icon.png",
      "infoPlist": {
        "NSCameraUsageDescription": "Gatly a besoin d'accéder à la caméra pour scanner les plaques."
      }
    },
    "android": {
      "package": "com.gatly.app",
      "permissions": [
        "INTERNET",
        "com.google.android.gms.permission.AD_ID",
        "android.permission.CAMERA"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#1E88E5",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "plugins": [
      "expo-router",
      "expo-localization",
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "Gatly a besoin d'accéder à la caméra pour scanner les plaques.",
          "enableMicrophonePermission": false
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#1E88E5",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-2586509557098502~6978159274",
          "iosAppId": "ca-app-pub-"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2c606953-0002-4472-9fff-a069a2781a12"
      }
    }
  }
}
